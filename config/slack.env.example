# Slack連携の設定。このファイルを config/slack.env にコピーして値を埋めてください。
# slack.env は .gitignore 済み(トークンをリポジトリにコミットしないこと)

# Bot User OAuth Token (OAuth & Permissions ページ。xoxb- で始まる)
SLACK_BOT_TOKEN=xoxb-your-token-here

# App-Level Token (Basic Information > App-Level Tokens。xapp- で始まる。scope: connections:write)
SLACK_APP_TOKEN=xapp-your-token-here

# 投稿先チャンネルID (チャンネル名を右クリック→リンクをコピー→末尾の C0123... 部分)
SLACK_CHANNEL_ID=C0123456789
